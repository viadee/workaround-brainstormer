# Environment Variables Configuration

## Required for Azure OpenAI API
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_API_URL=https://your-instance.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_CHAT_MODEL=gpt-4o
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

## Required for Authentication
APPSECRETKEY=your_secret_key_here
WAUSERNAME=your_username_here
WAPASSWORDHASH=your_password_hash_here
ADMINPASSWORDHASH=your_admin_password_hash_here
DAILYCOSTTHRESHOLD=10.0

## Required for Q-Drant Vector Database
QDRANT_URL=http://qdrant:6333
QDRANT_WORKAROUNDS_READ_KEY=your_qdrant_api_key_here

## Logging Configuration
# Set to 'dev' for development mode (detailed logging)
# Set to 'prod' for production mode (limited logging, API keys masked)
# Defaults to 'prod' if not specified
ENVIRONMENT=prod

# Examples:
# ENVIRONMENT=dev       # Verbose logging with full content
# ENVIRONMENT=prod      # Limited logging, sensitive data redacted
